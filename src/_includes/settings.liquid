<div>
    <button class="settings-menu-button" popovertarget="settings-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="2rem" height="2rem" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="feather feather-settings">
            <circle cx="12" cy="12" r="3"></circle>
            <path
                d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z">
            </path>
        </svg>
    </button>
    <menu id="settings-menu" class="settings-menu" popover>
        <fieldset>
            <legend>Theme</legend>
            <label>
                <input type="radio" name="theme" value="system"
                    data-on:click="$_darkTheme = ''; localStorage.removeItem('dark-theme')"
                    data-attr:checked="$_darkTheme === '' ? true : false">
                System
            </label>
            <label>
                <input type="radio" name="theme" value="light"
                    data-on:click="$_darkTheme = 'false'; localStorage.setItem('dark-theme', $_darkTheme)"
                    data-attr:checked="$_darkTheme === 'false' ? true : false">
                Light
            </label>
            <label>
                <input type="radio" name="theme" value="dark"
                    data-on:click="$_darkTheme = 'true'; localStorage.setItem('dark-theme', $_darkTheme)"
                    data-attr:checked="$_darkTheme === 'true' ? true : false">
                Dark
            </label>
        </fieldset>

        <fieldset>
            <legend>Colors</legend>
            <label>
                <span>--brand:</span>
                <input name="color" type="color" data-bind:_brand
                    data-on:change="localStorage.setItem('brand-color', $_brand)">
            </label>
            <label>
                <span>--color-degrees:</span>
                <input name="degrees" type="range" min="0" max="180" step="5" data-bind:_color-degrees
                    data-on:change="localStorage.setItem('color-degrees', $_colorDegrees)">
                    <input name="degrees-display" type="text" data-bind:_color-degrees disabled>
            </label>
            <button
                data-on:click="$_brand = '#238fff'; localStorage.removeItem('brand-color'); $_colorDegrees = 35;  localStorage.removeItem('color-degrees');">
                Reset
            </button>
        </fieldset>

        <fieldset>
            <legend>CSS</legend>
            <label>
                <input type="radio" name="css" value="enabled" data-on:click="$_cssToggle = true"
                    data-attr:checked="$_cssToggle">
                Enabled
            </label>
            <label>
                <input type="radio" name="css" value="disabled" data-on:click="$_cssToggle = false"
                    data-attr:checked="!$_cssToggle">
                Disabled
            </label>
        </fieldset>
    </menu>
</div>