<menu role="list">
    <li><a href="/">Home</a></li>
    <li><a href="/about">About</a></li>

    {% for topic in collections.orderedDocs %}
      {% assign isCurrentTopic = false %}
      
      <!-- Check if the current page belongs to any of the pages in this topic -->
      {% for item in topic.pages %}
        {% if page.url == item.url %}
          {% assign isCurrentTopic = true %}
        {% endif %}
      {% endfor %}

      <li>
        <details name="nav-sub-menu" {% if isCurrentTopic %}open{% endif %}>
          <!-- Uses the clean topic name from your JSON file -->
          <summary>{{ topic.name }}</summary>
          <menu role="list">
            {% for item in topic.pages %}
              <li>
                <a href="{{ item.url }}" {% if page.url == item.url %}aria-current="page"{% endif %}>
                  {{ item.title }}
                </a>
              </li>
            {% endfor %}            
          </menu>
        </details>
      </li>
    {% endfor %}
</menu>